# Example environment variables for Vercel production deployment
# Copy these values to your Vercel project settings
# DO NOT commit this file with actual values

# Django Configuration
DJANGO_SECRET_KEY=your-very-secure-random-key-of-at-least-50-characters
DJANGO_DEBUG=false
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_ENVIRONMENT=production

# Allowed hosts and CORS
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,yourproject-name.vercel.app
BACKEND_DOMAIN=https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://yourfrontend-domain.com

# Database - PostgreSQL (use Supabase, Railway, Neon, or similar)
DATABASE_URL=postgresql://user:password@host.region.provider.com:5432/dbname

# Redis - for caching and Celery (use Redis Cloud, Upstash, or similar)
REDIS_URL=redis://:password@host:port
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# Cloudinary - for media file storage (already configured)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (using SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Optional Configuration
OTP_EXPIRY_MINUTES=10

# Python Runtime
PYTHON_VERSION=3.12
